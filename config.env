# ============================================================================
# Green Code Gen - Central Configuration File
# ============================================================================
# This file contains all path configurations for the project.
# Update these paths when running on a different system.
# ============================================================================

# ----------------------------------------------------------------------------
# Project Paths
# ----------------------------------------------------------------------------
# Root directory of the project
PROJECT_ROOT="/path/to/green-tea"

# Sniper simulator installation
export SNIPER_ROOT="${PROJECT_ROOT}/sniper/sniper"

# PIE Dataset location
PIE_DATASET="${PROJECT_ROOT}/PIE_Dataset"

# ----------------------------------------------------------------------------
# Sniper Configuration
# ----------------------------------------------------------------------------
# Sniper config file (epyc_9554p.cfg - 64 cores, matches actual processor)
SNIPER_CONFIG="${SNIPER_ROOT}/config/epyc_9554p.cfg"

# ----------------------------------------------------------------------------
# Data Directories
# ----------------------------------------------------------------------------
# Execution master batch files
BATCH_DIR="${PIE_DATASET}/batches"

# Energy Pipeline Cache (Sniper Results) - DO NOT CHANGE
CACHE_DIR="${PROJECT_ROOT}/pie_energy_cache"

# System/Library Cache (HuggingFace, Pip, Wandb, etc.)
# This folder stores downloaded models and temporary build files.
# It is located on the project filesystem to avoid Home quota limits.
SYS_CACHE_DIR="${PROJECT_ROOT}/.cache"

# Output directory for detailed results
OUTPUT_DIR="${PROJECT_ROOT}/execution_results"

# Logs directory
LOG_DIR="${PROJECT_ROOT}/logs"

# ----------------------------------------------------------------------------
# Execution Parameters
# ----------------------------------------------------------------------------
# Conservative time estimate per execution (seconds) - 3x safety margin
TIME_PER_EXEC=75

# Sniper simulation timeout (seconds)
SNIPER_TIMEOUT=300

# Total number of batch files
NUM_BATCHES=440

# ----------------------------------------------------------------------------
# Python Environment
# ----------------------------------------------------------------------------
# Python virtual environment
VENV_DIR="${PROJECT_ROOT}/venv"

# ----------------------------------------------------------------------------
# System Configuration (usually don't need to change)
# ----------------------------------------------------------------------------
# PIN toolkit (part of Sniper)
PIN_HOME="${SNIPER_ROOT}/pin_kit"

# Python path for Sniper tools
SNIPER_PYTHONPATH="${SNIPER_ROOT}/mbuild"

# ============================================================================
# CACHE AND ENVIRONMENTS (Exported to ensure tools use project storage)
# ============================================================================

# Hugging Face cache (Models, Datasets)
export HF_HOME="${SYS_CACHE_DIR}/huggingface"

# Pip cache (Wheel downloads)
export PIP_CACHE_DIR="${SYS_CACHE_DIR}/pip"

# Triton cache (Unsloth/DeepSpeed kernels)
export TRITON_CACHE_DIR="${SYS_CACHE_DIR}/triton"

# Wandb cache/logs
export WANDB_DIR="${SYS_CACHE_DIR}/wandb"
export WANDB_CACHE_DIR="${SYS_CACHE_DIR}/wandb" # Some versions use this

# VLLM cache
export VLLM_HOME="${SYS_CACHE_DIR}/vllm"

# ============================================================================
# Usage in Scripts:
# ============================================================================
# Bash scripts:
#   source config.env
#
# Python scripts:
#   from dotenv import load_dotenv
#   load_dotenv('config.env')
#   PROJECT_ROOT = os.getenv('PROJECT_ROOT')
# ============================================================================
